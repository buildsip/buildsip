{
  "name": "buildsip",
  "version": "0.2.0",
  "description": "AI chats -> shareable stories",
  "license": "UNLICENSED",
  "type": "module",
  "homepage": "https://github.com/buildsip/buildsip#readme",
  "bugs": {
    "url": "https://github.com/buildsip/buildsip/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buildsip/buildsip.git",
    "directory": "packages/cli"
  },
  "bin": {
    "buildsip": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "buildsip": "pnpm build && node ./dist/index.js",
    "prepack": "pnpm build && node scripts/readme.mjs copy",
    "postpack": "node scripts/readme.mjs clean",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.21",
    "@clack/prompts": "^1.5.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@buildsip/agent-chat-parser": "workspace:*",
    "@buildsip/cli-auth": "workspace:*",
    "@buildsip/hooks": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "5.9.2"
  }
}
