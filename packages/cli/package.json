{
  "name": "buildsip",
  "version": "0.0.0",
  "description": "AI chats -> shareable stories",
  "private": true,
  "type": "module",
  "bin": {
    "buildsip": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
