    "@clack/prompts": "^1.5.1",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "5.9.2"
